# Neon Postgres — pooled connection, used at runtime by lib/db.ts (via @prisma/adapter-neon)
DATABASE_URL="postgresql://user:password@ep-example-pooler.region.aws.neon.tech/fudgee?sslmode=require&connect_timeout=15"

# Neon Postgres — direct/unpooled connection, used only by Prisma CLI (migrate/introspect) via prisma.config.ts
DIRECT_URL="postgresql://user:password@ep-example.region.aws.neon.tech/fudgee?sslmode=require"

# Auth.js
AUTH_SECRET="generate-with-npx-auth-secret"
AUTH_URL="http://localhost:3000"

# Stripe — storefront checkout payments (Dashboard > Developers > API keys / Webhooks)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
