// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Single-row settings for MVP; Phase 2 can normalize into multi-entity/multi-plant.
model Organization {
  id        String   @id @default(cuid())
  name      String
  timezone  String   @default("UTC")
  currency  String   @default("USD")
  address   String?
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Identity & RBAC ---
// DB-driven Role/Permission (not hardcoded enums) so Phase 2 roles/permissions
// are additions to the seed matrix, not scattered code changes.

model Role {
  id          String           @id @default(cuid())
  key         String           @unique // "super_admin","admin","production","warehouse","sales","finance","management"
  name        String
  description String?
  isSystem    Boolean          @default(true)
  permissions RolePermission[]
  users       User[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id     String           @id @default(cuid())
  key    String           @unique // e.g. "products:read", "products:write"
  module String
  action String
  roles  RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model User {
  id                    String                 @id @default(cuid())
  name                  String
  username              String                 @unique
  email                 String                 @unique
  emailVerified         DateTime?
  image                 String?
  passwordHash          String?
  isActive              Boolean                @default(true)
  mustChangePassword    Boolean                @default(false)
  roleId                String
  role                  Role                   @relation(fields: [roleId], references: [id])
  accounts              Account[]
  sessions              Session[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  inventoryTransactions InventoryTransaction[]
  qualityChecks         QualityCheck[]
  dispatchedShipments   Shipment[]
  lockedBatchNutritions BatchNutrition[]
  nutritionAuditLogs    NutritionAuditLog[]
  expenses              Expense[]

  @@index([roleId])
}

// --- Auth.js Prisma adapter tables ---
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- Core master data ---

enum ProductType {
  FINISHED_GOOD
  RAW_MATERIAL
  PACKAGING
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

model Product {
  id                    String                 @id @default(cuid())
  sku                   String                 @unique
  name                  String
  description           String?
  type                  ProductType            @default(FINISHED_GOOD)
  uom                   String
  status                ProductStatus          @default(ACTIVE)
  costPrice             Decimal?               @db.Decimal(14, 4)
  sellPrice             Decimal?               @db.Decimal(14, 4)
  reorderPoint          Decimal?               @db.Decimal(14, 4)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  purchaseOrderLines    PurchaseOrderLine[]
  salesOrderLines       SalesOrderLine[]
  inventoryTransactions InventoryTransaction[]
  productionBatches     ProductionBatch[]
  batchInputUsages      ProductionBatchInput[]
  recipe                Recipe?
  recipeLineUsages      RecipeLine[]
  batchCalcLineUsages   BatchCalculationLine[]
  packageItemUsages     PackageItem[]
  nutritionProfile      NutritionProfile?

  // Used as the "per serving" basis for the Nutrition Information Panel —
  // meaningful on finished goods, but not restricted to them (a raw
  // material could reasonably have one too).
  servingSizeGrams Decimal? @db.Decimal(10, 2)

  // --- Storefront marketing fields (all optional — purely additive, no
  // effect on the internal Products/Production/Inventory workflows) ---
  categoryId       String?
  category         Category?      @relation(fields: [categoryId], references: [id])
  imageUrl         String?
  shortDescription String?
  isFeatured       Boolean        @default(false)
  isBestSeller     Boolean        @default(false)
  images           ProductImage[]
  reviews          Review[]

  // --- Storefront product detail page fields (all optional, free text —
  // shown on the public product page only when filled in) ---
  ingredients         String?
  allergens           String?
  nutritionInfo       String?
  storageInstructions String?
  weight              String?
  shelfLife           String?
  deliveryInfo        String?
}

// Additional photos for a product's public gallery, beyond the single
// imageUrl already on Product (used as the primary/cover photo).
model ProductImage {
  id        String   @id @default(cuid())
  productId String
  imageUrl  String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Customer {
  id              String       @id @default(cuid())
  name            String
  code            String?      @unique
  email           String?
  phone           String?
  billingAddress  String?
  shippingAddress String?
  isActive        Boolean      @default(true)
  // Nullable — most Customer rows are still created by guest checkout with
  // no account at all. Set the moment this customer signs up for an
  // account (see modules/customer-account/actions.ts), which "claims" any
  // existing guest-checkout Customer row sharing that email rather than
  // creating a duplicate — so past guest orders show up in their history.
  passwordHash    String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  salesOrders     SalesOrder[]
  returns         Return[]
  invoices        Invoice[]
  sessions        CustomerSession[]
}

// A completely separate, DB-backed session mechanism for storefront
// customer accounts — deliberately not sharing anything with the staff
// NextAuth/User/Role system (per explicit product requirement: customer
// accounts must have no connection to the Operations dashboard). DB-backed
// (not a signed JWT) so logout/revocation is a real row delete, not just a
// client-side cookie clear.
model CustomerSession {
  id         String   @id @default(cuid())
  customerId String
  token      String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

// Its own table (not a text field) so Phase 2 can promote it to a full
// Suppliers module without a schema migration/rename. Full CRUD UI for this
// lands alongside Purchase Orders (M3); the model exists from M2.
model Supplier {
  id             String          @id @default(cuid())
  name           String
  code           String?         @unique
  email          String?
  phone          String?
  address        String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  purchaseOrders PurchaseOrder[]
  expenses       Expense[]
}

// --- Warehouse & Inventory (M4) ---

model Location {
  id                    String                 @id @default(cuid())
  name                  String
  code                  String?                @unique
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  inventoryTransactions InventoryTransaction[]
}

enum InventoryTransactionType {
  RECEIPT
  ISSUE
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
}

// A ledger, not a mutable balance table — current stock is computed via
// groupBy/sum over this table rather than kept in sync with a second write
// path. referenceType/referenceId are loose string pointers back to the
// PO/SO/batch that caused the movement (no FK, keeps this table decoupled).
model InventoryTransaction {
  id              String                   @id @default(cuid())
  productId       String
  locationId      String
  type            InventoryTransactionType
  quantity        Decimal                  @db.Decimal(14, 4)
  note            String?
  referenceType   String?
  referenceId     String?
  createdByUserId String?
  createdAt       DateTime                 @default(now())
  product         Product                  @relation(fields: [productId], references: [id])
  location        Location                 @relation(fields: [locationId], references: [id])
  createdByUser   User?                    @relation(fields: [createdByUserId], references: [id])

  @@index([productId, locationId])
}

// --- Purchase Orders (M3) ---

enum PurchaseOrderStatus {
  DRAFT
  SENT
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  seq          Int                 @default(autoincrement())
  supplierId   String
  status       PurchaseOrderStatus @default(DRAFT)
  orderDate    DateTime            @default(now())
  expectedDate DateTime?
  notes        String?
  subtotal     Decimal             @db.Decimal(14, 4)
  total        Decimal             @db.Decimal(14, 4)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  supplier     Supplier            @relation(fields: [supplierId], references: [id])
  lines        PurchaseOrderLine[]
}

model PurchaseOrderLine {
  id              String        @id @default(cuid())
  purchaseOrderId String
  productId       String
  quantity        Decimal       @db.Decimal(14, 4)
  unitCost        Decimal       @db.Decimal(14, 4)
  lineTotal       Decimal       @db.Decimal(14, 4)
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id])
}

// --- Sales Orders (M3) ---

// PACKED/DISPATCHED/DELIVERED are the Shipping module's flow (Confirmed ->
// Packed -> Dispatched -> Delivered). FULFILLED stays as the older one-step
// path for orders not going through Shipping — both are valid terminal-ish
// states, neither is "wrong."
enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  PACKED
  DISPATCHED
  DELIVERED
  FULFILLED
  CANCELLED
}

// Payment state for storefront checkouts via Stripe. Manually-entered orders
// (created outside the storefront) stay UNPAID indefinitely, which is fine —
// this only matters for orders that went through Stripe Checkout.
enum SalesOrderPaymentStatus {
  UNPAID
  PAID
  FAILED
  REFUNDED
}

model SalesOrder {
  id                      String                  @id @default(cuid())
  // @unique added so a manually-entered order number (see createSalesOrder)
  // can never collide with another order — enforced at the DB level, not
  // just in application code.
  seq                     Int                     @unique @default(autoincrement())
  customerId              String
  status                  SalesOrderStatus        @default(DRAFT)
  orderDate               DateTime                @default(now())
  requestedDate           DateTime?
  notes                   String?
  subtotal                Decimal                 @db.Decimal(14, 4)
  total                   Decimal                 @db.Decimal(14, 4)
  // GST component of `total` (Australian 10%, backed out of the
  // GST-inclusive price as total/11) — stored for BAS/tax reporting.
  gstAmount               Decimal?                @db.Decimal(14, 4)
  paymentStatus           SalesOrderPaymentStatus @default(UNPAID)
  stripeCheckoutSessionId String?                 @unique
  stripePaymentIntentId   String?
  // Set alongside paymentStatus flipping to PAID (Stripe webhook, or Finance's
  // recordInvoicePayment for wholesale orders) — gives Finance an accurate
  // "money actually received" date, since updatedAt can be bumped by any
  // unrelated field edit.
  paidAt                  DateTime?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  customer                Customer                @relation(fields: [customerId], references: [id])
  lines                   SalesOrderLine[]
  shipment                Shipment?
  invoiceLink             InvoiceSalesOrder?
}

model SalesOrderLine {
  id             String         @id @default(cuid())
  salesOrderId   String
  productId      String
  quantity       Decimal        @db.Decimal(14, 4)
  unitPrice      Decimal        @db.Decimal(14, 4)
  lineTotal      Decimal        @db.Decimal(14, 4)
  // Snapshot of Product.costPrice at the moment this line was created (stamped
  // by checkout-actions.ts and sales-orders/actions.ts) — Product.costPrice can
  // change later, so COGS/margin reporting needs the historical cost, not the
  // current one. Nullable because it's absent on lines created before this
  // column existed and where the product had no costPrice set at sale time.
  unitCostAtSale Decimal?       @db.Decimal(14, 4)
  salesOrder     SalesOrder     @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  product        Product        @relation(fields: [productId], references: [id])
  shipmentItems  ShipmentItem[]
}

// --- Recipes / formulations ---

// One recipe per finished good (MVP simplicity — no versioning). A "Master
// Formulation, Controlled Percentage Basis" document: each ingredient is a
// % of a defined base batch size, matching the format Dhanu already uses
// for her other formulation business.
model Recipe {
  id            String             @id @default(cuid())
  productId     String             @unique
  name          String?
  baseBatchSize Decimal?           @db.Decimal(14, 4)
  notes         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  product       Product            @relation(fields: [productId], references: [id])
  lines         RecipeLine[]
  calculations  BatchCalculation[]
}

model RecipeLine {
  id               String   @id @default(cuid())
  recipeId         String
  productId        String
  percentage       Decimal? @db.Decimal(9, 4)
  uin              String?
  controlStatus    String   @default("APPROVED")
  changeControlRef String?
  approvedBy       String?
  recipe           Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  product          Product  @relation(fields: [productId], references: [id])
}

// A saved, auditable "batch record" — scaling a Recipe to a real production
// run, with sign-off fields and a tolerance band per ingredient, rather than
// a throwaway on-screen calculation.
model BatchCalculation {
  id                String                 @id @default(cuid())
  recipeId          String
  seq               Int                    @default(autoincrement())
  batchNumber       String?
  requiredBatchSize Decimal                @db.Decimal(14, 4)
  tolerancePercent  Decimal                @default(2) @db.Decimal(5, 2)
  enteredBy         String?
  checkedBy         String?
  calculationDate   DateTime               @default(now())
  createdAt         DateTime               @default(now())
  recipe            Recipe                 @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  lines             BatchCalculationLine[]
}

model BatchCalculationLine {
  id                 String           @id @default(cuid())
  batchCalculationId String
  productId          String
  percentage         Decimal          @db.Decimal(9, 4)
  calculatedQty      Decimal          @db.Decimal(14, 4)
  roundedQty         Decimal          @db.Decimal(14, 4)
  minQty             Decimal          @db.Decimal(14, 4)
  maxQty             Decimal          @db.Decimal(14, 4)
  actualDispensed    Decimal?         @db.Decimal(14, 4)
  batchCalculation   BatchCalculation @relation(fields: [batchCalculationId], references: [id], onDelete: Cascade)
  product            Product          @relation(fields: [productId], references: [id])
}

// --- Production & Quality Control (M5) ---

enum ProductionBatchStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model ProductionBatch {
  id              String                 @id @default(cuid())
  seq             Int                    @default(autoincrement())
  productId       String
  quantityPlanned Decimal                @db.Decimal(14, 4)
  quantityActual  Decimal?               @db.Decimal(14, 4)
  quantityWaste   Decimal?               @db.Decimal(14, 4)
  status          ProductionBatchStatus  @default(PLANNED)
  startedAt       DateTime?
  completedAt     DateTime?
  notes           String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  product         Product                @relation(fields: [productId], references: [id])
  inputs          ProductionBatchInput[]
  qualityChecks   QualityCheck[]
  nutrition       BatchNutrition?
}

model ProductionBatchInput {
  id                String          @id @default(cuid())
  productionBatchId String
  productId         String
  quantity          Decimal         @db.Decimal(14, 4)
  productionBatch   ProductionBatch @relation(fields: [productionBatchId], references: [id], onDelete: Cascade)
  product           Product         @relation(fields: [productId], references: [id])
}

enum QualityResult {
  PASS
  FAIL
  PENDING
}

model QualityCheck {
  id                String          @id @default(cuid())
  productionBatchId String
  result            QualityResult   @default(PENDING)
  checkedAt         DateTime?
  checkedByUserId   String?
  notes             String?
  createdAt         DateTime        @default(now())
  productionBatch   ProductionBatch @relation(fields: [productionBatchId], references: [id], onDelete: Cascade)
  checkedByUser     User?           @relation(fields: [checkedByUserId], references: [id])
}

// --- Storefront (public marketing site + admin-manageable CMS content) ---
// Entirely new, additive models. The public site reads these plus the
// marketing fields added to Product above; checkout writes into the
// existing Customer/SalesOrder/SalesOrderLine models untouched (see
// modules/storefront/actions.ts) so the Sales/Customer modules and their
// schema are never modified by any of this.

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model GalleryItem {
  id        String   @id @default(cuid())
  imageUrl  String
  caption   String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id           String   @id @default(cuid())
  customerName String
  rating       Int      @default(5)
  body         String
  isFeatured   Boolean  @default(true)
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Null = a general site-wide testimonial (shown on the homepage). Set =
  // a review of that specific product, shown on its product detail page.
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model FaqItem {
  id        String   @id @default(cuid())
  question  String
  answer    String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Single-row settings for the public homepage's non-repeating copy (hero,
// about, contact, newsletter blurb) — same singleton pattern as
// Organization above, edited via one form rather than a collection.
model StorefrontSettings {
  id                   String   @id @default(cuid())
  heroHeading          String?
  heroSubheading       String?
  heroImageUrl         String?
  aboutHeading         String?
  aboutBody            String?
  aboutImageUrl        String?
  contactEmail         String?
  contactPhone         String?
  contactAddress       String?
  openingHours         String?
  whatsappNumber       String?
  instagramUrl         String?
  facebookUrl          String?
  tiktokUrl            String?
  newsletterHeading    String?
  newsletterSubheading String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model NewsletterSignup {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

// --- Shipping (M6) ---
// One Shipment per Sales Order (no partial/split shipments in this phase —
// salesOrderId is unique below). Dispatch is a status + captured detail on
// Shipment itself, not a separate table, since it's a transition, not a
// standalone record. Inventory is deducted here (at DISPATCHED), not at
// Sales Order confirmation/fulfillment — see dispatchShipment().

enum ShipmentStatus {
  WAITING
  PICKING
  PACKING
  PACKED
  READY_TO_DISPATCH
  DISPATCHED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  RETURNED
  CANCELLED
}

model Carrier {
  id           String     @id @default(cuid())
  name         String
  contactPhone String?
  contactEmail String?
  isActive     Boolean    @default(true)
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  shipments    Shipment[]
}

model Shipment {
  id                 String          @id @default(cuid())
  seq                Int             @default(autoincrement())
  salesOrderId       String          @unique
  carrierId          String?
  trackingNumber     String?
  status             ShipmentStatus  @default(WAITING)
  stockReserved      Boolean         @default(false)
  shipDate           DateTime?
  freightCost        Decimal?        @db.Decimal(14, 4)
  // Snapshot at creation time — SalesOrder/Customer don't store one, and an
  // address shouldn't silently change on an in-flight shipment if the
  // customer record is edited later.
  deliveryAddress    String?
  dispatchedAt       DateTime?
  dispatchedByUserId String?
  driverName         String?
  vehicleInfo        String?
  numberOfCartons    Int?
  signedBy           String?
  dispatchNotes      String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  salesOrder         SalesOrder      @relation(fields: [salesOrderId], references: [id])
  carrier            Carrier?        @relation(fields: [carrierId], references: [id])
  dispatchedByUser   User?           @relation(fields: [dispatchedByUserId], references: [id])
  items              ShipmentItem[]
  packages           Package[]
  trackingEvents     TrackingEvent[]
  returns            Return[]
}

model ShipmentItem {
  id               String         @id @default(cuid())
  shipmentId       String
  salesOrderLineId String
  quantity         Decimal        @db.Decimal(14, 4)
  shipment         Shipment       @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  salesOrderLine   SalesOrderLine @relation(fields: [salesOrderLineId], references: [id])
}

model Package {
  id         String        @id @default(cuid())
  shipmentId String
  boxType    String?
  weight     Decimal?      @db.Decimal(10, 3)
  lengthCm   Decimal?      @db.Decimal(8, 2)
  widthCm    Decimal?      @db.Decimal(8, 2)
  heightCm   Decimal?      @db.Decimal(8, 2)
  photoUrl   String?
  createdAt  DateTime      @default(now())
  shipment   Shipment      @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  items      PackageItem[]
}

model PackageItem {
  id        String  @id @default(cuid())
  packageId String
  productId String
  quantity  Decimal @db.Decimal(14, 4)
  package   Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

model TrackingEvent {
  id         String   @id @default(cuid())
  shipmentId String
  status     String
  location   String?
  note       String?
  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
}

enum ReturnStatus {
  REQUESTED
  INSPECTING
  APPROVED
  REJECTED
  REFUNDED
  REPLACED
}

model Return {
  id              String       @id @default(cuid())
  seq             Int          @default(autoincrement())
  customerId      String
  shipmentId      String?
  reason          String
  quantity        Decimal      @db.Decimal(14, 4)
  inspectionNotes String?
  refundAmount    Decimal?     @db.Decimal(14, 4)
  status          ReturnStatus @default(REQUESTED)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  customer        Customer     @relation(fields: [customerId], references: [id])
  shipment        Shipment?    @relation(fields: [shipmentId], references: [id])
}

// --- Nutrition (M7) ---
// NutritionProfile is the "ingredient nutrition database" — per-100g values
// entered once per Product. BatchNutrition is calculated by weighting each
// Recipe line's percentage against its ingredient's NutritionProfile; it
// starts as a live working record (editable, every change logged to
// NutritionAuditLog) and becomes a permanent locked snapshot the moment a
// PASS QualityCheck is recorded for that batch — see
// modules/nutrition/actions.ts's lockBatchNutritionOnPass, called from
// modules/quality/actions.ts's createQualityCheck.

model NutritionProfile {
  id             String   @id @default(cuid())
  productId      String   @unique
  energyKj       Decimal? @db.Decimal(10, 2)
  energyKcal     Decimal? @db.Decimal(10, 2)
  protein        Decimal? @db.Decimal(10, 3)
  totalFat       Decimal? @db.Decimal(10, 3)
  saturatedFat   Decimal? @db.Decimal(10, 3)
  transFat       Decimal? @db.Decimal(10, 3)
  carbohydrates  Decimal? @db.Decimal(10, 3)
  sugars         Decimal? @db.Decimal(10, 3)
  addedSugars    Decimal? @db.Decimal(10, 3)
  dietaryFibre   Decimal? @db.Decimal(10, 3)
  sodium         Decimal? @db.Decimal(10, 3)
  cholesterol    Decimal? @db.Decimal(10, 3)
  potassium      Decimal? @db.Decimal(10, 3)
  calcium        Decimal? @db.Decimal(10, 3)
  iron           Decimal? @db.Decimal(10, 3)
  // Anything not in the fixed list above — [{ name, value, unit }, ...].
  otherNutrients Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  product        Product  @relation(fields: [productId], references: [id])
}

model BatchNutrition {
  id                String              @id @default(cuid())
  productionBatchId String              @unique
  // Defaults from the finished good's Product.servingSizeGrams at creation,
  // but editable per batch (e.g. a batch packaged into a different size).
  servingSizeGrams  Decimal?            @db.Decimal(10, 2)
  energyKj          Decimal?            @db.Decimal(10, 2)
  energyKcal        Decimal?            @db.Decimal(10, 2)
  protein           Decimal?            @db.Decimal(10, 3)
  totalFat          Decimal?            @db.Decimal(10, 3)
  saturatedFat      Decimal?            @db.Decimal(10, 3)
  transFat          Decimal?            @db.Decimal(10, 3)
  carbohydrates     Decimal?            @db.Decimal(10, 3)
  sugars            Decimal?            @db.Decimal(10, 3)
  addedSugars       Decimal?            @db.Decimal(10, 3)
  dietaryFibre      Decimal?            @db.Decimal(10, 3)
  sodium            Decimal?            @db.Decimal(10, 3)
  cholesterol       Decimal?            @db.Decimal(10, 3)
  potassium         Decimal?            @db.Decimal(10, 3)
  calcium           Decimal?            @db.Decimal(10, 3)
  iron              Decimal?            @db.Decimal(10, 3)
  otherNutrients    Json?
  isLocked          Boolean             @default(false)
  lockedAt          DateTime?
  lockedByUserId    String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  productionBatch   ProductionBatch     @relation(fields: [productionBatchId], references: [id], onDelete: Cascade)
  lockedByUser      User?               @relation(fields: [lockedByUserId], references: [id])
  auditLogs         NutritionAuditLog[]
}

model NutritionAuditLog {
  id               String         @id @default(cuid())
  batchNutritionId String
  field            String
  oldValue         String?
  newValue         String?
  reason           String?
  changedByUserId  String?
  changedAt        DateTime       @default(now())
  batchNutrition   BatchNutrition @relation(fields: [batchNutritionId], references: [id], onDelete: Cascade)
  changedByUser    User?          @relation(fields: [changedByUserId], references: [id])
}

// --- Finance (M8) ---
// A pragmatic single-ledger design, not double-entry GL — matches the level
// of ambition of Dhanu's other finance system. Revenue/COGS/customer
// profitability are derived from existing SalesOrder/SalesOrderLine data
// (see modules/finance/lib/pnl.ts); Expense/Asset/Invoice are the only new
// manually-entered records. Invoice deliberately has no stored status column
// — Unpaid/Partially Paid/Paid is always derived from SUM(payments) vs
// totalAmount (modules/finance/lib/invoice-status.ts), so it can never drift
// from reality. Depreciation is computed on the fly (straight-line) from
// Asset, never persisted as rows — no cron needed.

enum FinanceExpenseCategory {
  RENT
  UTILITIES
  SALARIES_WAGES
  MARKETING
  PACKAGING_SUPPLIES
  MAINTENANCE
  INSURANCE
  OFFICE_SUPPLIES
  PROFESSIONAL_FEES
  // Logged here for cash-tracking on the Statement only — excluded from the
  // P&L's Operating Expenses so it's never double-counted against the
  // matching Asset's Depreciation.
  CAPITAL_ASSET_PURCHASE
  OTHER
}

enum FinancePaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  STRIPE
  CHEQUE
  OTHER
}

enum AssetCategory {
  MACHINERY
  VEHICLE
  BUILDING
  FURNITURE_FIXTURES
  IT_EQUIPMENT
  OTHER
}

enum AssetStatus {
  ACTIVE
  DISPOSED
}

model Expense {
  id              String                 @id @default(cuid())
  seq             Int                    @default(autoincrement())
  date            DateTime
  category        FinanceExpenseCategory
  amount          Decimal                @db.Decimal(14, 4)
  // Optional input-tax-credit side, for the GST Summary tab only — left null
  // if not tracked, never blocks saving an expense.
  gstAmount       Decimal?               @db.Decimal(14, 4)
  paymentMethod   FinancePaymentMethod
  note            String?
  supplierId      String?
  createdByUserId String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  supplier        Supplier?              @relation(fields: [supplierId], references: [id])
  createdByUser   User?                  @relation(fields: [createdByUserId], references: [id])

  @@index([date])
}

model Asset {
  id                       String        @id @default(cuid())
  seq                      Int           @default(autoincrement())
  name                     String
  category                 AssetCategory
  purchaseDate             DateTime
  purchaseCost             Decimal       @db.Decimal(14, 4)
  salvageValue             Decimal       @default(0) @db.Decimal(14, 4)
  depreciationPeriodMonths Int
  status                   AssetStatus   @default(ACTIVE)
  disposedAt               DateTime?
  notes                    String?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
}

model Invoice {
  id          String              @id @default(cuid())
  seq         Int                 @default(autoincrement())
  customerId  String
  issueDate   DateTime            @default(now())
  dueDate     DateTime?
  // Snapshot sum at generation time — SalesOrder lines/totals are never
  // edited after creation in this app, so this can't drift.
  totalAmount Decimal             @db.Decimal(14, 4)
  notes       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  customer    Customer            @relation(fields: [customerId], references: [id])
  salesOrders InvoiceSalesOrder[]
  payments    InvoicePayment[]
}

// Join table, not 1:1 — a wholesale customer's invoice may bundle several
// Sales Orders into one bill. @@unique(salesOrderId) prevents the same order
// being billed on two invoices.
model InvoiceSalesOrder {
  id           String     @id @default(cuid())
  invoiceId    String
  salesOrderId String     @unique
  amount       Decimal    @db.Decimal(14, 4)
  invoice      Invoice    @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id])
}

model InvoicePayment {
  id        String               @id @default(cuid())
  invoiceId String
  date      DateTime             @default(now())
  amount    Decimal              @db.Decimal(14, 4)
  method    FinancePaymentMethod
  reference String?
  note      String?
  createdAt DateTime             @default(now())
  invoice   Invoice              @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}
